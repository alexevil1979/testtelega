# ============================================
# TestTelega — Telegram Web Client / Tester
# Домен: testtelega.1tlt.ru
# Корень: /ssd/www/testtelega
# ============================================

APP_NAME="TestTelega"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://testtelega.1tlt.ru
APP_KEY=change_this_to_random_32_char_string

# Telegram API (получить на https://my.telegram.org/apps)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Прокси для MTProto (SOCKS5 / HTTP) — всегда используется при подключении к Telegram
PROXY_ENABLED=true
PROXY_URL=socks5://127.0.0.1:1084
HTTP_API_PROXY_URL=socks5://127.0.0.1:1084

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=testtelega
DB_USERNAME=testtelega
DB_PASSWORD=your_secure_password

# Пути (относительно корня проекта)
SESSIONS_PATH=sessions
LOGS_PATH=logs

# Безопасность
CSRF_TOKEN_NAME=_csrf_token
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Логирование MTProto
MTProto_LOG_ENABLED=true
MTProto_LOG_RETENTION_DAYS=30

# Часовой пояс
APP_TIMEZONE=Europe/Moscow

# PHP CLI (MadelineProto IPC worker — должен совпадать с FPM)
PHP_BIN=/usr/local/php82/bin/php
