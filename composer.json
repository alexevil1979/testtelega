{
    "name": "testtelega/web-client",
    "description": "Telegram Web Client / Tester на MadelineProto",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "danog/madelineproto": "^8.0",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    }
}
